# ========================================
# 企业级规章制度伴写系统 - 环境变量配置模板
# ========================================

# ----------------------------------------
# 1. 大模型提供商配置 (LLM_PROVIDER)
# 支持 'dashscope' (阿里百炼) 或 'azure' (企业内部 Azure OpenAI)
# ----------------------------------------
LLM_PROVIDER=dashscope

# 【选项 A】阿里百炼配置 (LLM_PROVIDER=dashscope 时生效)
DASHSCOPE_API_KEY=your_dashscope_api_key_here
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# 【选项 B】Azure OpenAI 配置 (LLM_PROVIDER=azure 时生效)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
OPENAI_API_VERSION=2024-12-01-preview
QWEN_EMBEDDING_MODEL=text-embedding-v4

# ----------------------------------------
# 2. 其他基础设施配置
# ----------------------------------------
# UI 展示模式：'opensource' 或 'company'
DISPLAY_TYPE=opensource

# Qdrant 向量数据库
QDRANT_HOST=localhost
QDRANT_PORT=6333

# 任务状态管理：'memory' 或 'redis'
TASK_STATE_MODE=memory
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
